{
	"name": "climbing-gear-ordering-system",
	"version": "0.1.0",
	"description": "攀岩设备下单系统 - 专业的攀岩装备在线订购平台",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "npm run db:generate:safe && next build",
		"build:analyze": "set ANALYZE=true && npm run build",
		"build:vercel": "next build",
		"build:production": "set NODE_ENV=production && npm run clean && npm run db:generate:safe && next build",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"dev": "next dev --turbo",
		"dev:performance": "next dev --turbo --port 3001",
		"start": "next start",
		"start:production": "set NODE_ENV=production && next start",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf .next out dist",
		"clean:all": "rimraf .next out dist node_modules package-lock.json",
		"db:push": "prisma db push",
		"db:studio": "prisma studio",
		"db:generate": "prisma generate",
		"db:generate:safe": "prisma generate || echo 'Prisma generate failed, continuing build'",
		"db:init": "node scripts/init-db.mjs",
		"db:reset": "prisma db push --force-reset && npm run db:init",
		"db:setup": "npm run db:generate && npm run db:push && npm run db:init",
		"db:migrate": "prisma migrate dev",
		"db:deploy": "prisma migrate deploy",
		"postinstall": "npm run db:generate:safe",
		"performance:check": "node scripts/performance-check.js",
		"size:analyze": "npx @next/bundle-analyzer",
		"setup:database": "node scripts/setup-database.mjs"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.0.1",
		"@prisma/client": "^6.9.0",
		"@radix-ui/react-accordion": "^1.2.11",
		"@radix-ui/react-alert-dialog": "^1.1.14",
		"@radix-ui/react-avatar": "^1.1.10",
		"@radix-ui/react-checkbox": "^1.3.2",
		"@radix-ui/react-dialog": "^1.1.14",
		"@radix-ui/react-dropdown-menu": "^2.1.15",
		"@radix-ui/react-label": "^2.1.7",
		"@radix-ui/react-popover": "^1.1.14",
		"@radix-ui/react-progress": "^1.1.7",
		"@radix-ui/react-radio-group": "^1.3.7",
		"@radix-ui/react-select": "^2.2.5",
		"@radix-ui/react-separator": "^1.1.7",
		"@radix-ui/react-slot": "^1.2.3",
		"@radix-ui/react-switch": "^1.2.5",
		"@radix-ui/react-tabs": "^1.1.12",
		"@radix-ui/react-tooltip": "^1.2.7",
		"@t3-oss/env-nextjs": "^0.12.0",
		"@types/pg": "^8.15.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"html2canvas": "^1.4.1",
		"jspdf": "^3.0.1",
		"lucide-react": "^0.511.0",
		"next": "^15.2.3",
		"pg": "^8.16.0",
		"prisma": "^6.9.0",
		"react": "^19.0.0",
		"react-day-picker": "^9.7.0",
		"react-dom": "^19.0.0",
		"react-hook-form": "^7.57.0",
		"react-to-print": "^3.1.0",
		"sonner": "^2.0.3",
		"tailwind-merge": "^3.3.1",
		"xlsx": "^0.18.5",
		"zod": "^3.24.2",
		"zustand": "^5.0.5"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@next/bundle-analyzer": "^15.2.3",
		"@tailwindcss/postcss": "^4.0.15",
		"@types/node": "^20.14.10",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"postcss": "^8.5.3",
		"rimraf": "^6.0.1",
		"tailwindcss": "^4.0.15",
		"tw-animate-css": "^1.3.0",
		"typescript": "^5.8.2"
	},
	"packageManager": "npm@10.7.0"
}
